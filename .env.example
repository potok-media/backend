# ==============================================================================
# Potok Backend Environment Configuration (Template)
# ==============================================================================

# Service ports (prepopulated with defaults)
GATEWAY_PORT=5000
SEARCH_ENGINE_PORT=6000
TORRENTGO_PORT=5282

# ==============================================================================
# DATABASE (PostgreSQL)
# ==============================================================================
# The connection string is assembled from these parts in docker-compose.yml,
# so there is no separate DATABASE_URL to maintain.
#
# DB_HOST = "db" uses the bundled PostgreSQL container. To use an external or
# shared database instead, set DB_HOST to its host/IP and remove the "db"
# service from docker-compose.yml.
DB_HOST=db
DB_PORT=5432
DB_NAME=potok
DB_USER=potok
DB_PASSWORD=changeme

# ==============================================================================
# REQUIRED USER CONFIGURATION
# ==============================================================================

# TMDB API key for movie metadata. Get yours at https://www.themoviedb.org/
GATEWAY_TMDB_API_KEY=

# Multi-user mode (allows self-registration of new users)
GATEWAY_MULTI_USER_MODE=false
