# ==============================================================================
# Potok Backend Environment Configuration (Template)
# ==============================================================================

# Service ports (prepopulated with defaults)
GATEWAY_PORT=5000
SEARCH_ENGINE_PORT=6000
TORRENTGO_PORT=5282

# ==============================================================================
# DATABASE (PostgreSQL)
# ==============================================================================
# The connection string is assembled from these parts in docker-compose.yml,
# so there is no separate DATABASE_URL to maintain.
#
# DB_HOST = "db" uses the bundled PostgreSQL container. To use an external or
# shared database instead, set DB_HOST to its host/IP and remove the "db"
# service from docker-compose.yml.
DB_HOST=db
DB_PORT=5432
DB_NAME=potok
DB_USER=potok
DB_PASSWORD=changeme

# ==============================================================================
# REQUIRED USER CONFIGURATION
# ==============================================================================

# TMDB API key for movie metadata. Get yours at https://www.themoviedb.org/
GATEWAY_TMDB_API_KEY=

# Multi-user mode (allows self-registration of new users)
GATEWAY_MULTI_USER_MODE=false

# ==============================================================================
# HARDWARE TRANSCODING (GPU) — optional
# ==============================================================================
# Non-H.264 media (e.g. HEVC / 10-bit) must be transcoded to H.264 for the browser.
# On a weak CPU (Intel N100, etc.) software transcode can't keep up and playback stalls.
#
# Pass a GPU into the container and TorrentGo auto-detects and uses it (VAAPI/QSV for
# Intel/AMD, NVENC for NVIDIA, VideoToolbox on macOS). It only enables an encoder that
# passes an on-startup probe (including keyframe alignment), else it stays on software.
# GPU device passthrough is a host grant the image can't self-do — uncomment on a host
# that actually has an Intel/AMD GPU (leaving it unset is safe on GPU-less hosts):
# GPU_DEVICE=/dev/dri:/dev/dri
#
# Force software encoding regardless of GPU (escape hatch if a GPU misbehaves):
# POTOK_DISABLE_HWACCEL=1
