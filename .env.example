# ==============================================================================
# Potok Backend Environment Configuration (Template)
# ==============================================================================

# Service Ports (Prepopulated with defaults)
GATEWAY_PORT=5000
SEARCH_ENGINE_PORT=6000
TORRENTGO_PORT=5282

# Internal service URLs inside docker-compose (Prepopulated with defaults)
GATEWAY_SEARCH_ENGINE_URL=http://potok-searchengine:6000
GATEWAY_TORRSERVER_URL=http://potok-torrentgo:5282

# ==============================================================================
# REQUIRED USER CONFIGURATION (Must be filled by the user)
# ==============================================================================

# PostgreSQL database connection string
# Example: Host=localhost;Port=5432;Database=potok;Username=postgres;Password=yourpassword;
DATABASE_URL=

# TMDB API Key for movie metadata
# Get yours from: https://www.themoviedb.org/
GATEWAY_TMDB_API_KEY=

# ==============================================================================
# FRONTEND / WEB CLIENT CONFIGURATION (Vite Environment Variables)
# ==============================================================================

# Port on which the web client will be accessible
WEB_PORT=3000

# Default URLs pre-filled in the settings or locked if lock mode is enabled.
# Leave blank to prompt the user for manual configuration on first load.
VITE_DEFAULT_BFF_URL=
VITE_DEFAULT_TORRENT_URL=
VITE_DEFAULT_SEARCH_URL=

# Flag to disable/lock the connection input fields (read-only mode)
# Set to 'true' to block public users from altering settings.
VITE_BLOCK_SETTINGS_INPUT=false

